# Copiá este archivo como .env.local para desarrollo local
# En Netlify: Site settings → Environment variables

# PIN compartido entre Hernán y Sofía
VITE_APP_PIN=

# Anthropic API key — server-side only (Netlify Function)
# Get yours at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Firebase — console.firebase.google.com → tu proyecto → Configuración
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
